{
  "name": "phrasepress",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "wizard": "node --import tsx/esm scripts/wizard.ts",
    "dev": "pnpm --filter @phrasepress/core dev",
    "dev:admin": "pnpm --filter @phrasepress/admin dev",
    "dev:all": "pnpm --parallel --filter @phrasepress/core --filter @phrasepress/admin dev",
    "build": "pnpm --filter @phrasepress/core build && pnpm --filter @phrasepress/admin build",
    "db:generate": "pnpm --filter @phrasepress/core db:generate",
    "db:migrate": "pnpm --filter @phrasepress/core db:migrate",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "better-sqlite3", "esbuild"]
  }
}
