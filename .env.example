# Path al file SQLite (relativo alla CWD del server, o assoluto)
DATABASE_PATH=./data/phrasepress.db

# Segreti JWT — generali con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-different-secret

# Password admin iniziale (usata solo al primo seed, poi ignorata)
ADMIN_PASSWORD=change-me-on-first-run

# Porta Fastify
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Origini CORS consentite (separare più origini con virgola)
CORS_ORIGIN=http://localhost:5173

# Dominio pubblico (usato da install.sh per generare la config Nginx)
DOMAIN=example.com
